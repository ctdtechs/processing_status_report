# Bootstrap connection to the Prod SQL instance that holds dbo.report_config.
# Copy this file to ".env" (same folder) and fill in real values:
#     cp .env.example .env
#
# The app loads .env automatically. Real shell environment variables, if
# set, take precedence over values here. Keep .env out of version control
# (it is git-ignored).

CONFIG_DB_SERVER=10.21.42.17,7865
CONFIG_DB_NAME=master
CONFIG_DB_USER=ABHIMASK
CONFIG_DB_PWD=change-me

# Optional: override the ODBC driver name if yours differs
# CONFIG_DB_DRIVER=ODBC Driver 18 for SQL Server


# =====================================================================
# Storage & system alert (separate email; run with: status_report.py --storage)
# Recipients are NOT here -- the storage alert uses the SAME to_mails/cc_mails
# from dbo.report_config as the processing-status report.
# File sizes are computed from the DB file paths (files.file_path,
# extractionDetails.{extractedFilePath,pickleInputPath,pickleOutputPath}),
# so no directory paths are configured here either.
# =====================================================================
STORAGE_ALERT_ENABLED=1
STORAGE_MOUNT=/data
# Alert fires when the mount's USED percentage reaches this:
STORAGE_THRESHOLD_PCT=80
# While still over threshold, re-alert at most once every N hours:
STORAGE_REMINDER_HOURS=2

# Optional: where the reminder de-dup state is kept.
# Default: <project_root>/.psr_storage_state.json
# STORAGE_STATE_FILE=/data/workflow_v2/processing_status_report/.psr_storage_state.json
